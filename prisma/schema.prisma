// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ユーザーテーブル（Auth.js用）
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  roleName      String?   @map("role_name")
  role          Role?     @relation(fields: [roleName], references: [name])
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

// OAuthアカウントテーブル（Auth.js用）
model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// セッションテーブル（Auth.js用）
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// メール認証用トークンテーブル（Auth.js用）
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// 管理者許可メールアドレステーブル
model AllowedAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  roleName  String   @map("role_name")
  role      Role     @relation(fields: [roleName], references: [name])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("allowed_admins")
}

// ロールマスターテーブル
model Role {
  name          String         @id
  description   String?
  users         User[]
  allowedAdmins AllowedAdmin[]
  createdAt     DateTime       @default(now()) @map("created_at")

  @@map("roles")
}

// カテゴリーテーブル
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

// 商品テーブル
model Product {
  id          Int       @id @default(autoincrement())
  name        String // 商品名（必須）
  description String    @db.Text // 商品説明（必須、長めのテキスト）
  imageUrl    String?   @map("image_url") // Blob StorageのURL
  priceS      Decimal?  @map("price_s") @db.Decimal(10, 2) // Sサイズの料金
  priceL      Decimal?  @map("price_l") @db.Decimal(10, 2) // Lサイズの料金
  categoryId  Int       @map("category_id") // カテゴリー（必須）
  category    Category  @relation(fields: [categoryId], references: [id])
  published   Boolean   @default(true) // 公開情報（true: 公開、false: 非公開）
  publishedAt DateTime? @map("published_at") // 公開日
  endedAt     DateTime? @map("ended_at") // 終了日
  displayOrder Int?     @map("display_order") // 表示順序（カテゴリー内での順序）
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("products")
}

// ===== レジCSVデータ取り込み関連テーブル =====

// 精算ヘッダーテーブル（全種別CSVの共通メタデータ）
// 設計判断: 5種別のCSVが同じメタデータを共有するため、親テーブルとして集約
model RegisterSettlement {
  id              Int      @id @default(autoincrement())
  machineNo       String   @map("machine_no")
  settlementCount Int      @map("settlement_count")
  date            DateTime @db.Date
  time            String
  createdAt       DateTime @default(now()) @map("created_at")

  salesSummaries  RegisterSalesSummary[]
  transactionKeys RegisterTransactionKey[]
  productSales    RegisterProductSale[]
  departmentSales RegisterDepartmentSale[]
  hourlySales     RegisterHourlySale[]
  importFiles     RegisterImportFile[]

  @@unique([machineNo, settlementCount, date, time])
  @@map("reg_settlements")
}

// 取り込み済みファイル管理テーブル（差分判定に使用）
model RegisterImportFile {
  id           Int                @id @default(autoincrement())
  fileName     String             @unique @map("file_name")
  fileType     String             @map("file_type")
  settlementId Int                @map("settlement_id")
  settlement   RegisterSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  importedAt   DateTime           @default(now()) @map("imported_at")

  @@map("reg_import_files")
}

// Z001: 売上明細テーブル（28行固定、全行登録）
model RegisterSalesSummary {
  id           Int                @id @default(autoincrement())
  settlementId Int                @map("settlement_id")
  settlement   RegisterSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  recordNo     Int                @map("record_no")
  itemName     String             @map("item_name")
  quantity     Int
  amount       Int

  @@unique([settlementId, recordNo])
  @@map("reg_sales_summaries")
}

// Z002: 取引キーテーブル（空白行は除外）
model RegisterTransactionKey {
  id           Int                @id @default(autoincrement())
  settlementId Int                @map("settlement_id")
  settlement   RegisterSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  recordNo     Int                @map("record_no")
  itemName     String             @map("item_name")
  quantity     Int
  amount       Int

  @@unique([settlementId, recordNo])
  @@map("reg_transaction_keys")
}

// Z004: 商品売上テーブル（個数・金額ともに0の行は除外）
model RegisterProductSale {
  id           Int                @id @default(autoincrement())
  settlementId Int                @map("settlement_id")
  settlement   RegisterSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  recordNo     Int                @map("record_no")
  itemCode     String             @map("item_code")
  itemName     String             @map("item_name")
  quantity     Int
  amount       Int

  @@unique([settlementId, recordNo])
  @@map("reg_product_sales")
}

// Z005: 部門売上テーブル（個数・金額ともに0の行は除外）
model RegisterDepartmentSale {
  id           Int                @id @default(autoincrement())
  settlementId Int                @map("settlement_id")
  settlement   RegisterSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  recordNo     Int                @map("record_no")
  itemName     String             @map("item_name")
  quantity     Int
  amount       Int

  @@unique([settlementId, recordNo])
  @@map("reg_department_sales")
}

// Z009: 時間帯別売上テーブル（件数・金額ともに0の行は除外）
model RegisterHourlySale {
  id           Int                @id @default(autoincrement())
  settlementId Int                @map("settlement_id")
  settlement   RegisterSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  recordNo     Int                @map("record_no")
  startTime    String             @map("start_time")
  endTime      String             @map("end_time")
  quantity     Int
  amount       Int

  @@unique([settlementId, recordNo])
  @@map("reg_hourly_sales")
}

// 期間プリセット（カスタム期間に名前を付けて保存）
model RegisterPeriodPreset {
  id        Int      @id @default(autoincrement())
  name      String
  dateFrom  DateTime @map("date_from") @db.Date
  dateTo    DateTime @map("date_to") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reg_period_presets")
}

// レジ番号の表示名（例: 14 → "入口レジ"）
model RegisterMachineName {
  id        Int      @id @default(autoincrement())
  machineNo String   @unique @map("machine_no")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reg_machine_names")
}

// 月間売上目標
model RegisterSalesTarget {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  amount    Int
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([year, month])
  @@map("reg_sales_targets")
}

// ダッシュボード表示設定（key-value形式）
model RegisterDashboardSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("reg_dashboard_settings")
}
